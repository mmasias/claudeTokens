{
  "manifest_version": 3,
  "name": "Claude Tokens",
  "version": "2.0.0",
  "description": "Monitor de uso semanal de tokens en Claude Code",
  "permissions": ["storage", "alarms", "nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
